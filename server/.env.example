# Copy this file to ".env" and fill in your values. Never commit your real .env.

# ---- OpenAI (required) ----
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Main agents model (quality). Router uses a cheaper model automatically.
OPENAI_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini
TEMPERATURE=0.6
MAX_TOKENS=1400

# ---- Server ----
PORT=8787
# Comma-separated origins allowed to call this backend ("*" = allow all, dev only)
ALLOWED_ORIGINS=*

# ---- Admin dashboard (leads / conversations / analytics) ----
# Pick a long random string; send it as "Authorization: Bearer <token>".
ADMIN_TOKEN=change-me-to-a-long-random-string

# ---- Persistence ----
PERSIST_CONVERSATIONS=true
# Optional custom SQLite path (defaults to ../data/xb2bx.db relative to src/db)
# SUPPLIERS_DB=
