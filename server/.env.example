# Copy this file to ".env" and fill in your values. Never commit your real .env.

# ---- OpenAI ----
# Can also be set/changed later from the admin panel (stored in the DB).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini
TEMPERATURE=0.6
MAX_TOKENS=1400

# ---- Supabase (required) ----
# Supabase project -> Settings -> API. Use the SERVICE ROLE key (server only).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Server ----
PORT=8787
# Comma-separated origins allowed to call this backend ("*" = allow all, dev only)
ALLOWED_ORIGINS=*

# ---- Admin panel login ----
# Email + password to sign in to the admin panel.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@123!
# Internal bearer token the panel uses after a successful login (long & secret).
ADMIN_TOKEN=change-me-to-a-long-random-string
